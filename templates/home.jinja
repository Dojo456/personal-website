{% extends "base.jinja" %}

{% block title %}Home{% endblock %}

{% block content_title %}
Welcome to My Personal Website
{% endblock %}

{% block content_description %}
<div>
    <p class="mb-2">Hi! My name is
        <code class="rainbow font-bold readable">Daniel Liao</code>. Thank's for coming in today. Here, have a cup of tea:
        <div class="w-full flex flex-row items-center justify-center gap-2 p-2 inverse-beveled mb-8">
        All beveled buttons are clickable. So click me -->
            <button class="beveled p-4" onclick="openTea()"><img src="{{ url_for('static', filename='assets/images/cute-pixel-art-green-tea-matcha-leaf-icon-illustration-png.webp') }}" alt="tea" width="24" height="24"></button>
        </div>
    </p>

    <p>
        I believe in clean energy, sustainable agriculture, queer rights, and education access.
    </p>

    <p>
        You can learn more about this by reading my <a class="link" href="{{ url_for('blog') }}">blogs</a>, viewing my <a class="link" href="{{ url_for('projects') }}">projects</a>, or reading below {{"(◑‿◐)"}}
    </p>

    <div class="flex justify-center w-full mt-8">
        <button class="beveled p-1" onclick="setAboutMeVisibility(true)">Learn more about me</button>
    </div>

    <div class="window beveled fixed hidden w-[700px] h-[500px]" style="top: 50%; left: 50%; transform: translate(-50%, -50%);" id="aboutMe">
        <h3 class="title-bar flex justify-between items-center cursor-move" id="aboutMeTitle">A little about me <button class="beveled text-black w-6 h-6 flex items-center justify-center font-extrabold" onclick="setAboutMeVisibility(false)">X</button></h3>
        <div class="p-2 pt-0">
            <div class="mb-4">
                <h4 class="text-xl">Education</h4>
                <div class="ps-8 text-xl">
                    <p> <span class="font-bold">B.S. in Business Administration</span> from 
                        <span class="p-1 beveled">
                            <a href="https://www.babson.edu" target="_blank" rel="noopener noreferrer">
                                <img class="inline" src="{{ url_for('static', filename='assets/babson-college.png') }}" alt="babson" width="16" height="16"> Babson College ↗
                            </a>
                        </span>
                    </p>

                    <p> <span class="font-bold">Certificate in Computer Science</span> from
                        <span class="p-1 beveled">
                            <a href="https://www.olin.edu" target="_blank" rel="noopener noreferrer">
                                <img class="inline" src="{{ url_for('static', filename='assets/olin-college.png') }}" alt="olin" width="16" height="16"> Olin College of Engineering ↗
                            </a>
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </div>

  
</div>

{% endblock %}

{% block scripts %}
<script>
    function setAboutMeVisibility(visibility) {
        if (visibility) {
            document.getElementById("aboutMe").classList.remove("hidden");
        } else {
            document.getElementById("aboutMe").classList.add("hidden");
        }
    }
</script>
{% endblock %}